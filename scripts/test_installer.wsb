<Configuration>
  <!--
    Clean-room test harness for StockPlan-Setup.exe.

    Double-click this file (after enabling Windows Sandbox) to launch a fresh,
    package-free Windows VM with the release folder mounted on the desktop.
    The sandbox resets completely on close, so every run is a true clean install.

    To test the app fully offline (proves it bundles ERTS and needs no
    downloads), change Networking to Disable below.
  -->
  <MappedFolders>
    <MappedFolder>
      <HostFolder>C:\Users\kvakatidev\Projects\wealth-management-stock-plan\release</HostFolder>
      <SandboxFolder>C:\Users\WDAGUtilityAccount\Desktop\release</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <!--
      Sample E*Trade files (Benefit History XLSX, Holdings XLSX, G&L_Expanded XLSX, etc.)
      mounted read-only so they can be uploaded into the app at localhost:4002
      without needing any network/download inside the VM. Read-only is safe: the
      app reads the file and copies its content into its own SQLite DB.
    -->
    <MappedFolder>
      <HostFolder>C:\Users\kvakatidev\Projects\wealth-management-stock-plan\docs\Sample-Data</HostFolder>
      <SandboxFolder>C:\Users\WDAGUtilityAccount\Desktop\sample-data</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <Networking>Default</Networking>
  <LogonCommand>
    <Command>explorer.exe C:\Users\WDAGUtilityAccount\Desktop\release</Command>
  </LogonCommand>
</Configuration>
